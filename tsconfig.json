{
  "compilerOptions": {
    "target": "es2025",
    "module": "esnext",
    "types": [ "node" ],
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "paths": {
      "@/abstract/*": [ "./src/abstract/*" ],
      "@/core/*": [ "./src/core/*" ],
      "@/interface/*": [ "./src/interfaces/*" ],
      "@/job/*": [ "./src/job/*" ],
      "@/lib/*": [ "./src/lib/*" ],
      "@/model/*": [ "./src/model/*" ],
      "@/parser/*": [ "./src/parser/*" ],
      "@/type/*": [ "./src/types/*" ],
      "@/util/*": [ "./src/utils/*" ]
    }
  },
  "tsc-alias": {
    "resolveFullPaths": true,
    "verbose": false
  },
  "include": [ "src" ],
  "exclude": [ "node_modules", "dist" ]
}
